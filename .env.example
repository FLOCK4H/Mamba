# Single-env setup (repo root): copy to `.env` and keep private.
#
#   cp .env.example .env
#
# Default values target Solana devnet (recommended).

########################################
# Core (shared)
########################################

# CHANGE THIS !!!!!!!!! Local authenticated backend + Create builders (required).
MAMBA_API_KEY="mamba_test_key"
# Canonical local signer used by:
# - mamba Create/Trade live sends
# - operator_live_tests (optional)
# - mamba_api swap execute=true (only if MAMBA_API_ENABLE_LIVE_SENDS=true)
#
# Format: base58-encoded 64-byte keypair OR JSON array of 64 bytes.
MAMBA_PRIVATE_KEY=""
# Default swap/create/pool priority fee level. Swap requests may now override this per request.
FEE_LEVEL="medium"
# Optional cap for computed/custom priority fee spend (in SOL).
# MAX_FEE="0.00005"

########################################
# Solana RPC endpoints
########################################

# Canonical comma-separated endpoint lists. Keep every URL on the same cluster.
# Reads/simulations rotate across the full HTTP pool and cool down rate-limited RPCs.
# For sustained mainnet websocket parsing, prefer at least 3 HTTP URLs across 2 providers.
MAMBA_API_HTTP_URLS="https://api.devnet.solana.com"
MAMBA_API_WS_URLS="wss://api.devnet.solana.com"
# Shared mint-route lookup budget (seconds). Increase only when your RPCs are slow.
MAMBA_ROUTE_LOOKUP_TIMEOUT_SECS="15"
# Swap submission/confirmation budget (seconds). If a tx does not land on-chain in this window,
# callers should surface an explicit "failed to confirm" error instead of a generic timeout.
MAMBA_SWAP_CONFIRM_TIMEOUT_SECS="60"

########################################
# mamba_api (backend) options
########################################

# Keep loopback-only by default.
MAMBA_API_BIND_ADDR="127.0.0.1:8787"
MAMBA_API_ROUTE_BASE="/mamba-api"

# Live sends are OFF by default (Create builders are build-only regardless).
MAMBA_API_ENABLE_LIVE_SENDS="true"
MAMBA_CLIENT_ALLOW_MAINNET_SEND=true
# When false, quick-trade live sends and MCP execute calls will stop on low-LQ routes
# and require an explicit user confirmation / override before proceeding.
AUTO_ACCEPT_LOW_LQ_POOLS="false"
